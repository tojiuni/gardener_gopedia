{
  "name": "sample_osteon_guide_30",
  "version": "1",
  "curation_tier": "bronze",
  "queries": [
    {
      "external_id": "osteon_01_base_os",
      "text": "Osteon 가이드 레이어 구조에서 베이스 OS로 명시된 것은 무엇인가?",
      "tier": "easy",
      "reference_answer": "Ubuntu 24.04 LTS (Base OS)"
    },
    {
      "external_id": "osteon_02_openstack_release",
      "text": "가이드에서 OpenStack IaaS로 명시한 릴리스(코드네임)는 무엇인가?",
      "tier": "easy",
      "reference_answer": "OpenStack Dalmatian (IaaS)"
    },
    {
      "external_id": "osteon_03_bastion_hostname",
      "text": "kolla-ansible 실행과 AI Agent 접속 기점으로 쓰는 Deploy 노드의 호스트네임은 무엇인가?",
      "tier": "easy",
      "reference_answer": "`ost-deploy`"
    },
    {
      "external_id": "osteon_04_controller_hostname",
      "text": "Controller 역할 노드의 호스트네임 예시는 무엇인가?",
      "tier": "easy",
      "reference_answer": "`ost-ctrl-01`"
    },
    {
      "external_id": "osteon_05_storage_hostname",
      "text": "Storage 역할(Cinder, LVM) 노드의 호스트네임 예시는 무엇인가?",
      "tier": "easy",
      "reference_answer": "`ost-stor-01`"
    },
    {
      "external_id": "osteon_06_cinder_disk",
      "text": "개요 레이어에서 Cinder 블록 스토리지에 예시로 든 디스크 용량은 얼마인가?",
      "tier": "easy",
      "reference_answer": "HDD 4TB"
    },
    {
      "external_id": "osteon_07_k8s_install_method",
      "text": "Kubernetes는 가이드에서 어떤 방식으로 설치한다고 되어 있는가?",
      "tier": "easy",
      "reference_answer": "kubeadm 직접 설치"
    },
    {
      "external_id": "osteon_08_iac_tool",
      "text": "OpenStack 리소스와 K8s manifest를 선언적으로 관리한다고 명시한 IaC 도구는 무엇인가?",
      "tier": "easy",
      "reference_answer": "OpenTofu (IaC)"
    },
    {
      "external_id": "osteon_09_iptime_api_repo",
      "text": "ipTIME-API(Go)로 안내하는 GitHub 저장소 경로는 무엇인가?",
      "tier": "medium",
      "reference_answer": "`github.com/Lyckabc/ipTIME-API`"
    },
    {
      "external_id": "osteon_10_mgmt_cidr",
      "text": "네트워크 설계에서 OpenStack Management 대역은 무엇으로 잡혀 있는가?",
      "tier": "easy",
      "reference_answer": "`192.168.10.0/24`"
    },
    {
      "external_id": "osteon_11_tunnel_cidr",
      "text": "OpenStack Tunnel(VXLAN)용으로 설계된 대역은 무엇인가?",
      "tier": "easy",
      "reference_answer": "`192.168.20.0/24`"
    },
    {
      "external_id": "osteon_12_storage_cidr",
      "text": "OpenStack Storage(Cinder 트래픽)용으로 설계된 대역은 무엇인가?",
      "tier": "easy",
      "reference_answer": "`192.168.30.0/24`"
    },
    {
      "external_id": "osteon_13_floating_pool",
      "text": "Floating IP 풀로 예약된 주소 범위는 무엇인가?",
      "tier": "easy",
      "reference_answer": "`192.168.0.200` ~ `192.168.0.250`"
    },
    {
      "external_id": "osteon_14_dhcp_range",
      "text": "ipTIME DHCP 범위를 Floating IP 풀과 겹치지 않게 조정할 때 가이드에 나온 범위는 무엇인가?",
      "tier": "easy",
      "reference_answer": "`192.168.0.2` ~ `192.168.0.199`"
    },
    {
      "external_id": "osteon_15_kolla_vip",
      "text": "예시로 든 kolla_internal_vip_address(VIP) 값은 무엇인가?",
      "tier": "easy",
      "reference_answer": "`192.168.10.100`"
    },
    {
      "external_id": "osteon_16_iptime_lan",
      "text": "ipTIME LAN(External/Provider)으로 설계 문서에 적힌 대역은 무엇인가?",
      "tier": "easy",
      "reference_answer": "`192.168.0.0/16`"
    },
    {
      "external_id": "osteon_17_cpu_virt_check",
      "text": "하드웨어 체크리스트에서 CPU 가상화 지원을 확인하는 egrep 명령 패턴은 무엇인가?",
      "tier": "medium",
      "reference_answer": "`egrep -c '(vmx|svm)' /proc/cpuinfo`"
    },
    {
      "external_id": "osteon_18_ram_controller",
      "text": "총 RAM이 64GB 이상일 때 권장 역할 배정은 무엇인가?",
      "tier": "easy",
      "reference_answer": "Controller + Compute 겸용 가능"
    },
    {
      "external_id": "osteon_19_kolla_ansible_version",
      "text": "kolla-ansible Dalmatian 설치에 맞춰 pip로 지정하는 버전 대역은 무엇인가?",
      "tier": "medium",
      "reference_answer": "`kolla-ansible==19.*`"
    },
    {
      "external_id": "osteon_20_kolla_genpwd",
      "text": "kolla 설정에서 패스워드 파일을 생성하는 명령은 무엇인가?",
      "tier": "easy",
      "reference_answer": "`kolla-genpwd`"
    },
    {
      "external_id": "osteon_21_kolla_etc_path",
      "text": "kolla-ansible 설정 파일이 위치하는 기본 경로는 어디인가?",
      "tier": "easy",
      "reference_answer": "`/etc/kolla`"
    },
    {
      "external_id": "osteon_22_multinode_deployment",
      "text": "multinode 인벤토리에서 deployment 그룹에 정의된 localhost 연결 방식은 무엇인가?",
      "tier": "medium",
      "reference_answer": "`localhost ansible_connection=local`"
    },
    {
      "external_id": "osteon_23_k8s_network_name",
      "text": "K8s용 OpenStack 네트워크를 만들 때 예시로 쓰는 네트워크 이름은 무엇인가?",
      "tier": "easy",
      "reference_answer": "`k8s-net`"
    },
    {
      "external_id": "osteon_24_k8s_subnet_cidr",
      "text": "k8s-subnet 생성 예시에서 subnet-range로 제시된 CIDR은 무엇인가?",
      "tier": "easy",
      "reference_answer": "`10.0.0.0/24`"
    },
    {
      "external_id": "osteon_25_k8s_keypair_name",
      "text": "K8s VM용 OpenStack keypair 생성 예시에서 사용하는 키 이름은 무엇인가?",
      "tier": "easy",
      "reference_answer": "`osteon-k8s-key`"
    },
    {
      "external_id": "osteon_26_opentofu_install",
      "text": "OpenTofu를 deb 방식으로 설치할 때 사용하는 설치 스크립트 URL은 무엇인가?",
      "tier": "medium",
      "reference_answer": "`https://get.opentofu.org/install-opentofu.sh`"
    },
    {
      "external_id": "osteon_27_clouds_yaml_cloud",
      "text": "clouds.yaml 예시에서 정의한 cloud 키 이름은 무엇인가?",
      "tier": "easy",
      "reference_answer": "`osteon`"
    },
    {
      "external_id": "osteon_28_iac_root",
      "text": "IaC 디렉토리 구조 예시에서 홈 아래 루트 폴더 이름은 무엇인가?",
      "tier": "easy",
      "reference_answer": "`~/osteon-iac`"
    },
    {
      "external_id": "osteon_29_hosts_ost_deploy",
      "text": "Ubuntu 설정에서 /etc/hosts에 넣는 ost-deploy의 Management IP 예시는 무엇인가?",
      "tier": "easy",
      "reference_answer": "`192.168.10.10`"
    },
    {
      "external_id": "osteon_30_troubleshoot_k8s02",
      "text": "트러블슈팅 가이드 [K8S-02]에서 Calico IPPool을 어떤 CIDR로 마이그레이션했다고 적혀 있는가?",
      "tier": "medium",
      "reference_answer": "`10.244.0.0/16`"
    }
  ],
