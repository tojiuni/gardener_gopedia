# PostgreSQL only. Either set a full URL, or leave empty and set POSTGRES_* below.
# GARDENER_DATABASE_URL=postgresql+psycopg://USER:PASSWORD@127.0.0.1:5432/gopedia?sslmode=disable
GARDENER_GOPEDIA_BASE_URL=http://127.0.0.1:18787
# Optional JSON search presets (Gopedia GET /api/search); omit for full results
# GARDENER_GOPEDIA_SEARCH_DETAIL=summary
# GARDENER_GOPEDIA_SEARCH_FIELDS=title,snippet,l3_id,score
GARDENER_GOPEDIA_SEARCH_RETRYABLE_MAX_ATTEMPTS=3
GARDENER_DEFAULT_TOP_K=10
GARDENER_DEFAULT_QUERY_TIMEOUT_S=15
# AI label auto-routing (POST /curation/batches)
# GARDENER_LABEL_AUTO_ACCEPT_SINGLE_MIN_CONFIDENCE=0.9
# GARDENER_LABEL_CONSENSUS_MIN_MODELS=2
# GARDENER_LABEL_CONSENSUS_MIN_CONFIDENCE=0.7
# Qrel resolution (target_data → ids via search)
# GARDENER_QREL_RESOLVE_SEARCH_DETAIL=standard
# GARDENER_QREL_RESOLVE_MIN_VECTOR_SCORE=0.25
# GARDENER_QREL_RESOLVE_MIN_COMBINED_SCORE=0.35
# GARDENER_QREL_RESOLVE_MAX_HITS_TO_SCORE=20
GARDENER_API_HOST=0.0.0.0
GARDENER_API_PORT=18880

# --- PostgreSQL (required if GARDENER_DATABASE_URL is unset) ---
# From the host (Gopedia compose publishes 5432): use POSTGRES_HOST=127.0.0.1
# From another container on the same compose network: use the service name, e.g. postgres_db
# GARDENER_POSTGRES_SCHEMA=gardener_eval
# POSTGRES_USER=admin_gopedia
# POSTGRES_PASSWORD=changeme
# POSTGRES_HOST=127.0.0.1
# POSTGRES_PORT=5432
# POSTGRES_DB=gopedia
# POSTGRES_SSLMODE=disable

# --- Optional: Ragas (LLM judge) + Phase-2 answer metrics ---
# GARDENER_RAGAS_ENABLED=true
# GARDENER_RAGAS_ANSWER_METRICS=false
# GARDENER_RAGAS_OPENAI_MODEL=gpt-4o-mini
# GARDENER_RAGAS_EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_API_KEY=sk-...

# --- Optional: Langfuse (see doc/runbook.md, scripts/langfuse-up.sh) ---
# GARDENER_LANGFUSE_ENABLED=true
# GARDENER_LANGFUSE_HOST=http://127.0.0.1:3000
# GARDENER_LANGFUSE_PUBLIC_KEY=pk-lf-...
# GARDENER_LANGFUSE_SECRET_KEY=sk-lf-...
