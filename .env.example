GARDENER_DATABASE_URL=sqlite:///./gardener.db
GARDENER_GOPEDIA_BASE_URL=http://127.0.0.1:18787
# Optional JSON search presets (Gopedia GET /api/search); omit for full results
# GARDENER_GOPEDIA_SEARCH_DETAIL=summary
# GARDENER_GOPEDIA_SEARCH_FIELDS=title,snippet,l3_id,score
GARDENER_GOPEDIA_SEARCH_RETRYABLE_MAX_ATTEMPTS=3
GARDENER_DEFAULT_TOP_K=10
GARDENER_DEFAULT_QUERY_TIMEOUT_S=15
GARDENER_API_HOST=0.0.0.0
GARDENER_API_PORT=18880

# --- Optional: PostgreSQL schema for Gardener tables (non-sqlite only) ---
# Create first: CREATE SCHEMA gardener_eval AUTHORIZATION your_user;
# GARDENER_POSTGRES_SCHEMA=gardener_eval

# --- Optional: Ragas (LLM judge) + Phase-2 answer metrics ---
# GARDENER_RAGAS_ENABLED=true
# GARDENER_RAGAS_ANSWER_METRICS=false
# GARDENER_RAGAS_OPENAI_MODEL=gpt-4o-mini
# GARDENER_RAGAS_EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_API_KEY=sk-...

# --- Optional: Phoenix OTLP (see docker-compose.phoenix.yml) ---
# GARDENER_PHOENIX_OTLP_ENDPOINT=http://127.0.0.1:6006/v1/traces
# GARDENER_PHOENIX_SERVICE_NAME=gardener-gopedia-eval
